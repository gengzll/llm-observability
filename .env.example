# =============================================================================
# 公用 LLM Provider (5 个 demo 都会用)
# =============================================================================
# 走 OpenAI 兼容协议, 可指向智谱 / DeepSeek / 火山 / 阿里通义 / OpenAI 官方 /
# 本地 vLLM 等任何 OpenAI-compatible 网关. agent 代码不动.
OPENAI_API_KEY=sk-xxx
# 可选: 自定义网关 (默认走 OpenAI 官方)
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/    # 智谱
# OPENAI_MODEL=glm-4-flash
# OPENAI_BASE_URL=https://api.deepseek.com/v1              # DeepSeek
# OPENAI_MODEL=deepseek-chat

# =============================================================================
# 1) LangSmith (仅云端 SaaS, 无开源自托管)
# =============================================================================
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_xxx
LANGSMITH_PROJECT=llm-obs-demo
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com   # 默认值, 欧盟区改为 .eu.

# =============================================================================
# 2) Langfuse (本地自托管: docker compose up, 默认 http://localhost:3000)
# =============================================================================
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=http://localhost:3000

# =============================================================================
# 3) Arize Phoenix (本地自托管: docker compose up, 默认 http://localhost:6006)
# =============================================================================
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
# 自托管模式下默认无 API key; 云端 (app.phoenix.arize.com) 需设置
# PHOENIX_API_KEY=xxx

# =============================================================================
# 4) Opik (本地自托管: ./opik.sh / .\opik.ps1, 默认 http://localhost:5173)
# =============================================================================
# 本地模式推荐使用 opik configure --use_local, 会写入 ~/.opik.config
# 也可直接通过环境变量配置:
OPIK_URL_OVERRIDE=http://localhost:5173/api
OPIK_WORKSPACE=default
# OPIK_API_KEY=xxx   # 仅 Comet Cloud 模式需要

# =============================================================================
# 5) MLflow (本地自托管: python mlflow_demo/00_launch_mlflow.py, 默认 :5000)
# =============================================================================
MLFLOW_TRACKING_URI=http://localhost:5000
# 若换端口 (与 Docker Desktop 之类冲突时):
# MLFLOW_TRACKING_URI=http://localhost:5001
